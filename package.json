{
  "name": "node-red-contrib-surrealdb",
  "version": "0.1.0",
  "description": "Node-RED palette for SurrealDB with resilient connection handling",
  "license": "MIT",
  "main": "index.js",
  "keywords": [
    "node-red",
    "surrealdb",
    "database"
  ],
  "scripts": {
    "prepare": "husky install",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "test:integration": "node --test test/integration/connection-manager.integration.test.js",
    "test:integration:auth": "node --test test/integration/*auth*.test.js",
    "test:integration:resilience": "node --test test/integration/*resilience*.test.js",
    "precommit:fix": "lint-staged"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "node-red": "^4.0.9",
    "node-red-node-test-helper": "^0.3.5",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "surrealdb": "^1.0.0"
  },
  "node-red": {
    "nodes": {
      "surrealdb-config": "nodes/surrealdb-config.js",
      "surrealdb-insert": "nodes/surrealdb-insert.js",
      "surrealdb-query": "nodes/surrealdb-query.js",
      "surrealdb-relate": "nodes/surrealdb-relate.js",
      "surrealdb-upsert": "nodes/surrealdb-upsert.js",
      "surrealdb-modify": "nodes/surrealdb-modify.js",
      "surrealdb-select": "nodes/surrealdb-select.js",
      "surrealdb-delete": "nodes/surrealdb-delete.js",
      "surrealdb-live": "nodes/surrealdb-live.js"
    }
  }
}
